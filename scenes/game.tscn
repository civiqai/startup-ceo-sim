[gd_scene load_steps=5 format=3 uid="uid://game"]

[ext_resource type="Script" path="res://scripts/game.gd" id="1"]
[ext_resource type="Theme" path="res://resources/theme.tres" id="2"]
[ext_resource type="Script" path="res://scripts/office_view.gd" id="3"]

[sub_resource type="StyleBoxFlat" id="header_style"]
bg_color = Color(0.10, 0.11, 0.16, 1.0)
border_width_bottom = 1
border_color = Color(0.22, 0.25, 0.32, 1.0)
content_margin_left = 20.0
content_margin_top = 10.0
content_margin_right = 20.0
content_margin_bottom = 10.0

[node name="Game" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
theme = ExtResource("2")
script = ExtResource("1")

[node name="BgColor" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.08, 0.09, 0.12, 1.0)

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
theme_override_constants/separation = 0

[node name="Header" type="PanelContainer" parent="VBox"]
layout_mode = 2
theme_override_styles/panel = SubResource("header_style")

[node name="HBox" type="HBoxContainer" parent="VBox/Header"]
layout_mode = 2

[node name="MonthLabel" type="Label" parent="VBox/Header/HBox"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_colors/font_color = Color(1.0, 1.0, 1.0, 1.0)
theme_override_font_sizes/font_size = 26
text = "1ヶ月目"

[node name="CashLabel" type="Label" parent="VBox/Header/HBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.55, 0.85, 0.55, 1.0)
theme_override_font_sizes/font_size = 26
text = "💰 1000万円"
horizontal_alignment = 2

[node name="OfficeView" type="Control" parent="VBox"]
layout_mode = 2
size_flags_vertical = 3
custom_minimum_size = Vector2(0, 400)
script = ExtResource("3")

[node name="LogTicker" type="PanelContainer" parent="VBox"]
layout_mode = 2

[node name="LogLabel" type="RichTextLabel" parent="VBox/LogTicker"]
layout_mode = 2
custom_minimum_size = Vector2(0, 60)
theme_override_font_sizes/normal_font_size = 20
bbcode_enabled = true
text = "さあ、経営を始めよう！"
scroll_following = true
scroll_active = false

[node name="ActionBar" type="MarginContainer" parent="VBox"]
layout_mode = 2
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 8
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 16

[node name="ActionBtn" type="Button" parent="VBox/ActionBar"]
