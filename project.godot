; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="IT社長物語"
config/description="IT社長経営シミュレーションゲーム"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "Mobile")

[autoload]

GameState="*res://scripts/game_state.gd"
AudioManager="*res://scripts/audio_manager.gd"
TeamManager="*res://scripts/team_manager.gd"
SaveManager="*res://scripts/save_manager.gd"
DifficultyManager="*res://scripts/difficulty_manager.gd"
KenneyTheme="*res://scripts/kenney_theme.gd"
AvatarLoader="*res://scripts/avatar_loader.gd"
FurnitureData="*res://scripts/furniture_data.gd"
OfficeBuffManager="*res://scripts/office_buff_manager.gd"
FurnitureManager="*res://scripts/furniture_manager.gd"
OfficeExpansionManager="*res://scripts/office_expansion_manager.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_width"
window/handheld/orientation=1

[gui]

theme/custom="res://resources/theme.tres"
theme/custom_font="res://assets/fonts/NotoSansJP-Regular.ttf"

[input_devices]

pointing/emulate_touch_from_mouse=true

[rendering]

renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
