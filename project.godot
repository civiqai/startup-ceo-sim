; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be manually edited with care.

[application]

config/name="IT社長物語"
config/description="IT社長経営シミュレーションゲーム"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3", "Mobile")

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/size/mode=2
window/stretch/mode="viewport"
window/stretch/aspect="keep_width"
window/handheld/orientation=1

[input_devices]

pointing/emulate_touch_from_mouse=true

[autoload]

GameState="*res://scripts/game_state.gd"
AudioManager="*res://scripts/audio_manager.gd"
TeamManager="*res://scripts/team_manager.gd"
SaveManager="*res://scripts/save_manager.gd"
DifficultyManager="*res://scripts/difficulty_manager.gd"
KenneyTheme="*res://scripts/kenney_theme.gd"
AvatarLoader="*res://scripts/avatar_loader.gd"

[gui]

theme/custom="res://resources/theme.tres"
theme/custom_font="res://assets/fonts/NotoSansJP-Regular.ttf"

[rendering]

renderer/rendering_method="mobile"
textures/canvas_textures/default_texture_filter=1
textures/vram_compression/import_etc2_astc=true
